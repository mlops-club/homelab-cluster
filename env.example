# Homelab cluster environment variables
#
# Copy to .env and fill in secrets:
#   cp env.example .env
#
# Secrets are loaded from ~/credentials/homelab.env (see below).
# Non-secret config is set directly here.

# ── Secrets (loaded from ~/credentials/homelab.env) ──────────────
# That file should export:
#   CLOUDFLARE_API_TOKEN              — https://dash.cloudflare.com/profile/api-tokens
#                                       Permissions: Zone:Zone:Read, Zone:DNS:Edit, Account:Cloudflare Tunnel:Edit
#   TAILSCALE_CLIENT_ID               — https://login.tailscale.com/admin/settings/trust-credentials
#   TAILSCALE_CLIENT_SECRET             Permissions: General>Services:write, Devices>Core:write, Keys>Auth Keys:write
#   HARBOR_PASSWORD                   — openssl rand -base64 24
#   HARBOR_SECRET_KEY                 — openssl rand -base64 32 (stable across upgrades)
#   BETTERSTACK_SANDBOX_INGEST_TOKEN  — source token from the Sandbox team's
#                                       eric-sandbox Telemetry source
#                                       (https://telemetry.betterstack.com/team/t556480/sources/2518436/data-ingestion)
source ~/credentials/homelab.env

# ── Cloudflare (non-secret identifiers) ──────────────────────────
# Account ID: right sidebar at https://dash.cloudflare.com/<account-id>/<domain>
export CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"
# Zone ID: right sidebar on the same page
export CLOUDFLARE_ZONE_ID="your-cloudflare-zone-id"
export DOMAIN="mlops-club.org"

# ── Let's Encrypt ────────────────────────────────────────────────
export ACME_EMAIL="your-email@example.com"

# ── Harbor (private container registry) ──────────────────────────
export HARBOR_ADMIN_PASSWORD="${HARBOR_PASSWORD}"

# ── NFS CSI (NAS-backed storage) ─────────────────────────────────
# server: Tailscale hostname of the NAS (resolves to 100.117.142.58)
export NFS_SERVER="nas"
export NFS_SHARE="/volume1/k8s-homelab"
export NFS_STORAGE_CLASS_NAME="nas-nfs"
export NFS_NAMESPACE="nfs-system"
export NFS_MOUNT_OPTIONS="nfsvers=3,nolock"

# ── Come Follow Me App ───────────────────────────────────────────
export CFM_APP_VERSION="0.5.0"
export CFM_APP_GOOGLE_CREDENTIALS_PATH="$HOME/credentials/come-follow-me-google-svc-account.json"
export CFM_APP_SPREADSHEET_ID="12zv4FtCf_Lkpn2Vgm8WekSING4Bh6hf3keL7-yyqM-8"

# ── Seminary Feedback App ────────────────────────────────────────
export SEMINARY_APP_VERSION="0.3.1"
export SEMINARY_GOOGLE_CREDENTIALS_PATH="$HOME/credentials/seminary-feedback-google-svc-account.json"
export SEMINARY_SPREADSHEET_ID="1YE_fpeudNs89YZCZyRkHd_WfOQ4v3naUzUolQkN8Ce4"
